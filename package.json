{
    "name": "react-amnesia",
    "version": "0.1.0",
    "description": "AI-friendly application undo/redo (CTRL+Z) for React",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": {
                "import": "./dist/index.d.ts",
                "require": "./dist/index.d.cts"
            },
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./core": {
            "types": {
                "import": "./dist/core.d.ts",
                "require": "./dist/core.d.cts"
            },
            "import": "./dist/core.js",
            "require": "./dist/core.cjs",
            "default": "./dist/core.js"
        },
        "./mnemonic": {
            "types": {
                "import": "./dist/mnemonic.d.ts",
                "require": "./dist/mnemonic.d.cts"
            },
            "import": "./dist/mnemonic.js",
            "require": "./dist/mnemonic.cjs",
            "default": "./dist/mnemonic.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "tsc -p tsconfig.json --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "docs:ai": "node ./scripts/generate-agent-instructions.mjs",
        "ai:check": "node ./scripts/generate-agent-instructions.mjs --check"
    },
    "keywords": [
        "react",
        "react-hooks",
        "undo",
        "redo",
        "history",
        "command-pattern",
        "ctrl-z",
        "typescript",
        "ai-friendly"
    ],
    "author": "Scott Dixon",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thirtytwobits/react-amnesia.git"
    },
    "homepage": "https://thirtytwobits.github.io/react-amnesia/",
    "bugs": {
        "url": "https://github.com/thirtytwobits/react-amnesia/issues"
    },
    "engines": {
        "node": ">=18"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "react-mnemonic": ">=1.5.0"
    },
    "peerDependenciesMeta": {
        "react-mnemonic": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.0.1",
        "@testing-library/user-event": "^14.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^3.2.4",
        "fast-check": "^4.7.0",
        "jsdom": "^25.0.1",
        "prettier": "^3.6.2",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-mnemonic": "^1.5.0",
        "tsup": "^8.3.5",
        "typescript": "^5.7.3",
        "vitest": "^3.2.4"
    },
    "sideEffects": false
}
